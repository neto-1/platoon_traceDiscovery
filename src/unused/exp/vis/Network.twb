        <named-connections>
          <named-connection caption='Neo4j' name='webdata-direct.0nanyp00xbeebf1g0hmmg1u1iqbn'>
            <connection ACCESSTOKEN='' APIVersion='' CLIENTID='' CLIENTSECRET='' REDIRECT_URI='' REFRESHTOKEN='' SCOPE='' access-token-expires-in='' access-token-issue-time='' authType='basic' authentication='yes' channel='https' class='webdata-direct' connectionData='{&quot;config&quot;:{&quot;url&quot;:&quot;bolt://localhost:7687&quot;,&quot;inspectRows&quot;:&quot;1000&quot;,&quot;tableNames&quot;:[&quot;Locations&quot;,&quot;Lines&quot;,&quot;Table3&quot;,&quot;Table4&quot;,&quot;Table5&quot;],&quot;cypherQueries&quot;:[&quot;MATCH (n:loc) RETURN n.lon, n.lat&quot;,&quot;MATCH p=(n:loc)-[r:NEIGHBOUR]-&gt;(m:loc)\nWITH [x in nodes(p) | (x)] AS nodeLinkIds, r,n,m\nUNWIND nodeLinkIds AS l\nRETURN id(n) as node1,id(m) as node2, l.lon, l.lat,id(r) as line, (6378.388*acos(sin(n.lon*(pi()/180))*sin(m.lon*(pi()/180))+cos(n.lon*(pi()/180))*cos(m.lon*(pi()/180))*cos(m.lat*(pi()/180) - n.lat*(pi()/180)))) as distance LIMIT 100000&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;]}}' connectionName='Neo4j' filename='Neo4jWdc2.html' id-token='' increment-key='' oauth-client='' path='/neo4j-tableau/website/' port='443' scriptVersion='' secondary_whitelist='' server='neo4j-contrib.github.io' urlQuery='' username='neo4j' usernameAlias='' />
          </named-connection>
        </named-connections>
