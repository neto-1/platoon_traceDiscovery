      <connection class='federated'>
        <named-connections>
          <named-connection caption='Neo4j' name='webdata-direct.0t36lu00lakg8m1f8vwaz1w23ryl'>
            <connection ACCESSTOKEN='' APIVersion='' CLIENTID='' CLIENTSECRET='' REDIRECT_URI='' REFRESHTOKEN='' SCOPE='' access-token-expires-in='' access-token-issue-time='' authType='basic' authentication='yes' channel='https' class='webdata-direct' connectionData='{&quot;config&quot;:{&quot;url&quot;:&quot;bolt://localhost&quot;,&quot;inspectRows&quot;:&quot;1000&quot;,&quot;tableNames&quot;:[&quot;Lines&quot;,&quot;Table2&quot;,&quot;Table3&quot;,&quot;Table4&quot;,&quot;Table5&quot;],&quot;cypherQueries&quot;:[&quot;MATCH p=(n:loc)-[r:NEIGHBOUR]-&gt;(m:loc) WITH [x in nodes(p) | (x)] AS nodeLinkIds, r,n,m\nUNWIND nodeLinkIds AS l\nRETURN id(n) as node1,id(m) as node2, l.lon, l.lat,id(r) as line, (6378.388*acos(sin(n.lon*(pi()/180))*sin(m.lon*(pi()/180))+cos(n.lon*(pi()/180))*cos(m.lon*(pi()/180))*cos(m.lat*(pi()/180) - n.lat*(pi()/180)))) as distance, \&quot;road\&quot; AS type LIMIT 100000\nUNION\nMATCH (vs:VehicleSet) WITH MAX(vs.id) as maxvs\nMATCH (vs:VehicleSet)-[r:INSET]-&gt;(v:Vehicle),(el)-[:END]-(v:Vehicle)-[:START]-(sl) WHERE vs.id=maxvs\nWITH sl, el, id(v) as vid LIMIT 100000\ncall proceduretest.aStarPlugin(id(sl), id(el), &apos;distance&apos;, &apos;lat&apos;, &apos;lon&apos;, &apos;coordinates&apos;, [&apos;NEIGHBOUR&apos;], [], [], &apos;both&apos;) yield path\nWITH vid, nodes(path) AS path_nodes\nUNWIND range(0, size(path_nodes)-2) AS i\nWITH path_nodes[i] AS n, path_nodes[i+1] AS m, \&quot;vehicle_\&quot; + vid AS type\nMATCH p=(n)-[r:NEIGHBOUR]-(m)\nWITH [x in nodes(p) | (x)] AS nodeLinkIds, r, n, m ,type\nUNWIND nodeLinkIds AS l\nRETURN id(n) as node1,id(m) as node2, l.lon, l.lat,id(r) as line, (6378.388*acos(sin(n.lon*(pi()/180))*sin(m.lon*(pi()/180))+cos(n.lon*(pi()/180))*cos(m.lon*(pi()/180))*cos(m.lat*(pi()/180) - n.lat*(pi()/180)))) as distance, type LIMIT 100000&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;]}}' connectionName='Neo4j' filename='Neo4jWdc2.html' id-token='' increment-key='' oauth-client='' path='/neo4j-tableau/website/' port='443' scriptVersion='' secondary_whitelist='' server='neo4j-contrib.github.io' urlQuery='' username='neo4j' usernameAlias='' />
          </named-connection>
        </named-connections>
