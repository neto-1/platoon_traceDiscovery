p12 <- c(7.09039259,49.12018204 );
p22 <- c(6.744044304, 49.51861191);
#p12 = start of veh 1
#p22 = end of veh 1
p13 <- c(7.040774822, 49.14577484);
p23 <- c(6.959856987, 49.60663223);
#p13 = start of veh 2
#p23 = end of veh 2
lengthOfPlatoonDist <- function(x) {
sum ( sqrt( (p12[1] - x[1])^2 + (p12[2] - x[2])^2 ) + sqrt( (p13[1] - x[1])^2 + (p13[2] - x[2])^2 ) + sqrt( (p22[1] - x[3])^2 + (p22[2] - x[4])^2 ) + sqrt( (p23[1] - x[3])^2 + (p23[2] - x[4])^2 ) + sqrt( (x[1] -x[3])^2 + (x[2] - x[4])^2 ) * (2-lw))
}
