    <datasource caption='Road Network' inline='true' name='federated.1q3qgrc152hygx0zu611n172dq69' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='Neo4j' name='webdata-direct.1svvrvc0eozg8l1b7n2tk1b23i3t'>
            <connection ACCESSTOKEN='' APIVersion='' CLIENTID='' CLIENTSECRET='' REDIRECT_URI='' REFRESHTOKEN='' SCOPE='' access-token-expires-in='' access-token-issue-time='' authType='basic' authentication='yes' channel='http' class='webdata-direct' connectionData='{&quot;config&quot;:{&quot;url&quot;:&quot;bolt://localhost&quot;,&quot;inspectRows&quot;:&quot;1000&quot;,&quot;tableNames&quot;:[&quot;Road&quot;,&quot;Group&quot;,&quot;Table3&quot;,&quot;Table4&quot;,&quot;Table5&quot;],&quot;cypherQueries&quot;:[&quot;MATCH (n:primary)-[r:ROAD_SEGMENT]-&gt;(m:primary)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;primary&apos; AS type\nUNION\nMATCH (n:primary_link)-[r:ROAD_SEGMENT]-&gt;(m:primary_link)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;primary_link&apos; AS type\nUNION\nMATCH (n:motorway)-[r:ROAD_SEGMENT]-&gt;(m: motorway)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;motorway&apos; AS type\nUNION\nMATCH (n:motorway_link)-[r:ROAD_SEGMENT]-&gt;(m:motorway_link)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;motorway_link&apos; AS type\nUNION\nMATCH (n:trunk)-[r:ROAD_SEGMENT]-&gt;(m: trunk)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;trunk&apos; AS type\nUNION\nMATCH (n:trunk_link)-[r:ROAD_SEGMENT]-&gt;(m:trunk_link)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;trunk_link&apos; AS type\nUNION\nMATCH (d:Depot)-[r:LOCATED_AT]-&gt;(road:RoadPoint)\nRETURN road.lat AS Latitude, road.lon AS Longitude, ID(r) AS Line_Group, ID(d) AS OrderOfPoints, &apos;Depot&apos; AS type&quot;,&quot;MATCH (g:Group) \nWITH g \nCALL apoc.coll.partition(g.polygon,2) \nYIELD value \nWITH collect(value) as coords, g \nWITH coords, g, range(0, length(coords)) as iter \nWITH g, coords, iter, EXTRACT(i IN RANGE(0, LENGTH(iter) - 2) | [coords[i], iter[i]]) AS result WITH g, result  UNWIND result as res\nRETURN id(g) as shape, res[0][0] as Longitude, res[0][1] as Latitude, res[1] as point&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;]}}' connectionName='Neo4j' filename='Neo4jWdc2.html' id-token='' increment-key='' oauth-client='' path='/tableau-neo4j-wdc/v2.3/' port='80' scriptVersion='' secondary_whitelist='' server='ralfbecher.github.io' urlQuery='' username='neo4j' usernameAlias='' />
          </named-connection>
        </named-connections>
