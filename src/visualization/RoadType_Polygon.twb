            <connection ACCESSTOKEN='' APIVersion='' CLIENTID='' CLIENTSECRET='' REDIRECT_URI='' REFRESHTOKEN='' SCOPE='' access-token-expires-in='' access-token-issue-time='' authType='basic' authentication='yes' channel='http' class='webdata-direct' connectionData='{&quot;config&quot;:{&quot;url&quot;:&quot;bolt://localhost&quot;,&quot;inspectRows&quot;:&quot;1000&quot;,&quot;tableNames&quot;:[&quot;Group&quot;,&quot;Table2&quot;,&quot;Table3&quot;,&quot;Table4&quot;,&quot;Table5&quot;],&quot;cypherQueries&quot;:[&quot;MATCH (n1:RoadPoint)&lt;-[:START_AT]-(n:Vehicle)-[:END_AT]-&gt;(n2:RoadPoint) WITH n1, n2, n as vehicle CALL apoc.algo.aStar(n1, n2, &apos;ROAD_SEGMENT&gt;&apos;, &apos;distance_meter&apos;,&apos;lat&apos;,&apos;lon&apos;) YIELD path, weight WITH nodes(path) as road, relationships(path) as relations, vehicle UNWIND relations as r WITH r, vehicle MATCH (n:RoadPoint)-[r]-&gt;(m:RoadPoint) \nWITH [n, m] AS roads, r, vehicle\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;vehicle&apos; AS type, id(road) AS id, id(vehicle) as vehicle_id&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;]}}' connectionName='Neo4j' filename='Neo4jWdc2.html' id-token='' increment-key='' oauth-client='' path='/tableau-neo4j-wdc/v2/' port='80' scriptVersion='' secondary_whitelist='' server='ralfbecher.github.io' urlQuery='' username='neo4j' usernameAlias='' />
