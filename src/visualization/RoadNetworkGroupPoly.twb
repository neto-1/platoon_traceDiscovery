            <connection ACCESSTOKEN='' APIVersion='' CLIENTID='' CLIENTSECRET='' REDIRECT_URI='' REFRESHTOKEN='' SCOPE='' access-token-expires-in='' access-token-issue-time='' authType='basic' authentication='yes' channel='https' class='webdata-direct' connectionData='{&quot;config&quot;:{&quot;url&quot;:&quot;bolt://localhost&quot;,&quot;inspectRows&quot;:&quot;1000&quot;,&quot;tableNames&quot;:[&quot;Road&quot;,&quot;Table2&quot;,&quot;Table3&quot;,&quot;Table4&quot;,&quot;Table5&quot;],&quot;cypherQueries&quot;:[&quot;MATCH (n:primary)-[r:ROAD_SEGMENT]-&gt;(m:primary)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;primary&apos; AS type, &apos;segment&apos; AS category\nUNION\nMATCH (n:primary_link)-[r:ROAD_SEGMENT]-&gt;(m:primary_link)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;primary_link&apos; AS type, &apos;segment&apos; AS category\nUNION\nMATCH (n:motorway)-[r:ROAD_SEGMENT]-&gt;(m: motorway)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;motorway&apos; AS type, &apos;segment&apos; AS category\nUNION\nMATCH (n:motorway_link)-[r:ROAD_SEGMENT]-&gt;(m:motorway_link)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;motorway_link&apos; AS type, &apos;segment&apos; AS category\nUNION\nMATCH (n:trunk)-[r:ROAD_SEGMENT]-&gt;(m: trunk)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;trunk&apos; AS type, &apos;segment&apos; AS category\nUNION\nMATCH (n:trunk_link)-[r:ROAD_SEGMENT]-&gt;(m:trunk_link)\nWITH [n, m] AS roads, r\nUNWIND roads AS road\nRETURN road.lat AS Latitude, road.lon AS Longitude, id(r) AS Line_Group, ID(road) AS OrderOfPoints, &apos;trunk_link&apos; AS type, &apos;segment&apos; AS category\nUNION\nMATCH (d:Depot)-[r:LOCATED_AT]-&gt;(road:RoadPoint)\nRETURN road.lat AS Latitude, road.lon AS Longitude, ID(r) AS Line_Group, ID(d) AS OrderOfPoints, &apos;Depot&apos; AS type, &apos;depot&apos; AS category\nUNION\nMATCH (road:RoadPoint)\nRETURN road.lat AS Latitude, road.lon AS Longitude, ID(road) AS Line_Group, ID(road) AS OrderOfPoints, &apos;RoadPoint&apos; AS type, &apos;point&apos; AS category&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;]}}' connectionName='Neo4j' filename='Neo4jWdc2.html' id-token='' increment-key='' oauth-client='' path='/neo4j-tableau/website/' port='443' scriptVersion='' secondary_whitelist='' server='neo4j-contrib.github.io' urlQuery='' username='neo4j' usernameAlias='' />
